{
  "manifest_version": 3,
  "name": "CSES Problem Finder",
  "version": "1.1.0",
  "description": "Random CSES problem picker with timer",
  "icons": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" },
  "action": { "default_popup": "popup/popup.html", "default_icon": "icons/icon48.png" },
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    { "matches": ["https://cses.fi/problemset/list*"], "js": ["content.js"], "run_at": "document_idle" },
    { "matches": ["https://cses.fi/problemset/task/*"], "js": ["content_task.js"], "run_at": "document_idle" }
  ],
  "permissions": ["storage", "tabs", "scripting", "alarms", "notifications"],
  "host_permissions": ["https://cses.fi/*"]
}
