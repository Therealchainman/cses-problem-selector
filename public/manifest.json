{
  "manifest_version": 3,
  "name": "CSES Problem Finder",
  "version": "2.0.0",
  "description": "Random CSES problem picker with sidebar stats",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://cses.fi/problemset/*", "https://cses.fi/problemset"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["storage"],
  "host_permissions": ["https://cses.fi/*"]
}
